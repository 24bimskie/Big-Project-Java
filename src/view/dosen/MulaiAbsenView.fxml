<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.dosen.MulaiAbsenController"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;" stylesheets="@../../style/style.css">
    <content>
        <VBox styleClass="content-pane" spacing="20">
            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button fx:id="btnKembali" text="← Kembali" styleClass="btn-secondary" />
                <Label text="Mulai Absensi Kelas" styleClass="header-title" />
            </HBox>

            <VBox styleClass="card" spacing="15">
                <GridPane hgap="25" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="100" prefWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    
                    <Label text="Mata Kuliah:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblMatkul" text="-" style="-fx-font-size: 14px; -fx-text-fill: #1e293b; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Kelas:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblKelas" text="-" style="-fx-font-size: 14px; -fx-text-fill: #1e293b; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Hari / Jam:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label fx:id="lblHariJam" text="-" style="-fx-font-size: 14px; -fx-text-fill: #1e293b; -fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    
                    <Label text="Pilih Tanggal:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <DatePicker fx:id="datePickerTanggal" prefWidth="200" styleClass="date-picker" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                </GridPane>
            </VBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Daftar Mahasiswa" styleClass="card-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblJumlahSiswa" text="Total: 0 Mahasiswa" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                </HBox>
                
                <TableView fx:id="tableMahasiswa" styleClass="table-view" VBox.vgrow="ALWAYS" minHeight="350">
                    <columns>
                        <TableColumn fx:id="colNo" text="No" prefWidth="60" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colNim" text="NIM" prefWidth="150" style="-fx-alignment: CENTER-LEFT;" />
                        <TableColumn fx:id="colNama" text="Nama Lengkap" prefWidth="250" style="-fx-alignment: CENTER-LEFT;" />
                        <TableColumn fx:id="colKehadiran" text="Kehadiran" prefWidth="200" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colKeterangan" text="Keterangan" prefWidth="250" style="-fx-alignment: CENTER-LEFT;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                
                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button fx:id="btnReset" text="Reset Kehadiran" styleClass="btn-secondary" />
                    <Button fx:id="btnSimpan" text="Simpan Absensi" styleClass="btn-primary" />
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>