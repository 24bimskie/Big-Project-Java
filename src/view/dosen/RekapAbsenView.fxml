<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.dosen.RekapAbsenController"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;" stylesheets="@../../style/style.css">
    <content>
        <VBox styleClass="content-pane" spacing="20">
            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>
            
            <Label text="Rekap Absensi Mahasiswa" styleClass="header-title" />

            <VBox styleClass="card" spacing="15">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Mata Kuliah:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" minWidth="-Infinity" />
                    <ComboBox fx:id="comboMataKuliahRekap" promptText="-- Semua Mata Kuliah --" prefWidth="250" styleClass="combo-box" />
                    
                    <Label text="Tanggal:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" minWidth="-Infinity" />
                    <DatePicker fx:id="datePickerRekap" promptText="Tanggal Absen" styleClass="text-field" />
                    
                    <Button fx:id="btnFilter" text="Filter" styleClass="btn-primary" minWidth="-Infinity" />
                    <Button fx:id="btnExportPdf" text="Export PDF" styleClass="btn-secondary" minWidth="-Infinity" />
                </HBox>
            </VBox>

            <HBox spacing="20">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Persentase Kehadiran" styleClass="card-title" />
                    <Label text="0%" styleClass="card-value" style="-fx-text-fill: #10b981;" />
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Mahasiswa Sering Alpha" styleClass="card-title" />
                    <Label text="0 Orang" styleClass="card-value" style="-fx-text-fill: #ef4444;" />
                </VBox>
            </HBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
                <Label text="Data Kehadiran Detail" styleClass="card-title" minWidth="-Infinity" />
                <TableView fx:id="tableRekap" styleClass="table-view" VBox.vgrow="ALWAYS" minHeight="300">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colRekapNim" text="NIM" prefWidth="120" />
                        <TableColumn fx:id="colRekapNama" text="Nama Mahasiswa" prefWidth="250" />
                        <TableColumn fx:id="colRekapHadir" text="Hadir" prefWidth="100" />
                        <TableColumn fx:id="colRekapIzin" text="Izin" prefWidth="100" />
                        <TableColumn fx:id="colRekapSakit" text="Sakit" prefWidth="100" />
                        <TableColumn fx:id="colRekapAlpha" text="Alpha" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </content>
</ScrollPane>