<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.dosen.RekapAbsenController"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;" stylesheets="@../../style/style.css">
    <content>
        <VBox styleClass="content-pane" spacing="20">
            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button fx:id="btnKembali" text="← Kembali" styleClass="btn-secondary" />
                <Label text="Rekap Absensi Mahasiswa" styleClass="header-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Tahun Ajaran 2025 - 2026" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
                <Button fx:id="btnRefresh" text="Refresh" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 40px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button fx:id="btnCetak" text="Cetak Rekap" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 40px; -fx-background-radius: 8px; -fx-cursor: hand;" />
            </HBox>

            <VBox styleClass="card" spacing="15">
                <GridPane hgap="25" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="100" prefWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    
                    <Label text="Mata Kuliah:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblMatkul" text="-" style="-fx-font-size: 14px; -fx-text-fill: #1e293b; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Kelas:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblKelas" text="-" style="-fx-font-size: 14px; -fx-text-fill: #1e293b; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Hari / Jam:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label fx:id="lblHariJam" text="-" style="-fx-font-size: 14px; -fx-text-fill: #1e293b; -fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                </GridPane>
            </VBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
                <Label text="Data Kehadiran" styleClass="card-title" />
                
                <TableView fx:id="tableRekap" styleClass="table-view" VBox.vgrow="ALWAYS" minHeight="350">
                    <!-- Dynamic Table Columns loaded via Controller -->
                </TableView>
                
                <HBox alignment="CENTER_LEFT" spacing="25" style="-fx-padding: 10 0 0 0;">
                    <Label text="Keterangan Legend:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="M : Masuk / Hadir" style="-fx-font-weight: bold; -fx-text-fill: #10b981;" />
                        <Label text="I : Izin" style="-fx-font-weight: bold; -fx-text-fill: #3b82f6;" />
                        <Label text="S : Sakit" style="-fx-font-weight: bold; -fx-text-fill: #f59e0b;" />
                        <Label text="A : Alpha" style="-fx-font-weight: bold; -fx-text-fill: #ef4444;" />
                    </HBox>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>