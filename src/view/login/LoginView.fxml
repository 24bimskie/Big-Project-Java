<?xml version="1.0" encoding="UTF-8"?>
<!-- View Login - Halaman awal aplikasi -->
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.LoginController"
            prefWidth="800" prefHeight="500" styleClass="login-pane">

    <VBox alignment="CENTER" spacing="15.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <Text text="Sistem Absensi Mahasiswa" styleClass="login-title">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Text>
        
        <Text text="Silakan Login" />

        <VBox maxWidth="300" spacing="10.0">
            <Label text="Username" />
            <TextField fx:id="usernameField" promptText="Masukkan username" styleClass="text-field" />
            
            <Label text="Password" />
            <PasswordField fx:id="passwordField" promptText="Masukkan password" styleClass="text-field" />
            
            <Button text="Login" onAction="#handleLogin" maxWidth="Infinity" styleClass="btn-primary" />
            
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="Belum punya akun?" />
                <Hyperlink text="Daftar di sini" onAction="#handleGoToRegister" />
            </HBox>
        </VBox>
    </VBox>

</AnchorPane>
