<?xml version="1.0" encoding="UTF-8"?>
<!-- View Dashboard Dosen -->
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.dosen.DosenDashboardController"
            prefWidth="1100" prefHeight="700" styleClass="dashboard-pane" stylesheets="@../../style/style.css, @../../style/Dosen.css">

    <!-- TOP: Header dengan info user -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header" prefHeight="70">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            <Button fx:id="btnToggleSidebar" text="☰" styleClass="btn-secondary" minWidth="-Infinity" />
            <Label text="Sistem Akademik - Dashboard Dosen" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER" spacing="10">
                <children>
                    <TextField fx:id="txtSearch" promptText="Cari data mahasiswa..." styleClass="search-field" prefWidth="250" />
                    <Button fx:id="btnCari" text="Cari" styleClass="btn-primary" minWidth="-Infinity" />
                </children>
            </HBox>
            
            <VBox alignment="CENTER_RIGHT" spacing="5">
                <Label fx:id="lblNamaDosen" text="Nama Dosen" styleClass="header-user"/>
                <Label text="Role: Dosen" styleClass="header-role"/>
            </VBox>
            <Circle radius="18" fill="#cbd5e1" />
        </HBox>
    </top>

    <!-- LEFT: Sidebar menu navigasi -->
    <left>
        <VBox fx:id="sidebar" spacing="5" styleClass="sidebar" prefWidth="250">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>
            
            <Label text="Menu Utama" styleClass="sidebar-title" />
            
            <Button fx:id="btnJadwalMengajar" text="Jadwal Mengajar" styleClass="sidebar-btn" maxWidth="Infinity" />
            <Button fx:id="btnDataDosen" text="Data Dosen" styleClass="sidebar-btn" maxWidth="Infinity" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button fx:id="btnLogout" text="Logout" styleClass="btn-logout" maxWidth="Infinity">
                <VBox.margin>
                    <Insets top="10" right="5" bottom="0" left="5"/>
                </VBox.margin>
            </Button>
            
        </VBox>
    </left>

    <!-- CENTER: Content area -->
    <center>
        <StackPane fx:id="papanKontenTengah" styleClass="content-pane">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
        </StackPane>
    </center>
</BorderPane>