<?xml version="1.0" encoding="UTF-8"?>
<!-- View Register - Halaman Pendaftaran Khusus Mahasiswa -->
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.RegisterController"
            prefWidth="800" prefHeight="700" styleClass="login-pane">

    <VBox alignment="CENTER" spacing="15.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <Text text="Registrasi Mahasiswa" styleClass="login-title">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Text>
        
        <Text text="Silakan isi kelengkapan data untuk mendaftar" />

        <VBox maxWidth="350" spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="NIM:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="nimField" promptText="Masukkan NIM" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Nama Lengkap:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="namaField" promptText="Masukkan Nama" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Jenis Kelamin:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <fx:define>
                        <ToggleGroup fx:id="genderGroup"/>
                    </fx:define>
                    <RadioButton fx:id="radioL" text="Laki-laki" toggleGroup="$genderGroup"/>
                    <RadioButton fx:id="radioP" text="Perempuan" toggleGroup="$genderGroup"/>
                </HBox>

                <Label text="Program Studi:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <ComboBox fx:id="prodiComboBox" promptText="Pilih Prodi" maxWidth="Infinity" styleClass="combo-box" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Kelas:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="kelasComboBox" promptText="Pilih Kelas" maxWidth="Infinity" styleClass="combo-box" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="Alamat:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextField fx:id="alamatField" promptText="Masukkan Alamat" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <PasswordField fx:id="passwordField" promptText="Masukkan password" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                <Label text="Konfirmasi Pass:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Ulangi password" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
            </GridPane>
            
            <Button text="Daftar" onAction="#handleRegister" maxWidth="Infinity" styleClass="btn-primary" style="-fx-margin-top: 10px;" />
            
            <Label fx:id="statusLabel" textFill="red" alignment="CENTER" maxWidth="Infinity" wrapText="true"/>
            
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="Sudah punya akun?" />
                <Hyperlink text="Login di sini" onAction="#handleBackToLogin" />
            </HBox>
        </VBox>
    </VBox>

</AnchorPane>
