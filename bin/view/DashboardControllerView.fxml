<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            prefWidth="1200" prefHeight="800" styleClass="dashboard-pane" 
            stylesheets="@../style/style.css">

    <!-- LEFT: Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="250">
            <!-- App Logo / Title -->
            <Label text="Sistem PMB" styleClass="sidebar-title" />
            
            <Separator opacity="0.2" />
            
            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="20"/>
                </VBox.margin>
                <Button text="Dashboard" styleClass="sidebar-btn, active" maxWidth="Infinity" />
                <Button text="Data Mahasiswa" styleClass="sidebar-btn" maxWidth="Infinity" />
                <Button text="Pendaftaran" styleClass="sidebar-btn" maxWidth="Infinity" />
                <Button text="Pengumuman" styleClass="sidebar-btn" maxWidth="Infinity" />
            </VBox>
            
            <!-- Bottom: Logout -->
            <Button text="Logout" styleClass="sidebar-btn" maxWidth="Infinity" />
        </VBox>
    </left>

    <!-- CENTER: Main Content Area -->
    <center>
        <BorderPane>
            <!-- TOP: Header -->
            <top>
                <HBox styleClass="header-pane" alignment="CENTER_LEFT" spacing="20">
                    <Label text="Dashboard Utama" styleClass="header-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    
                    <!-- Search Bar untuk CRUD -->
                    <HBox alignment="CENTER" spacing="10">
                        <TextField promptText="Cari data..." styleClass="text-field" prefWidth="250"/>
                        <Button text="Search" styleClass="btn-primary" />
                    </HBox>
                    
                    <Pane HBox.hgrow="ALWAYS" />
                    
                    <!-- Profile Area -->
                    <HBox alignment="CENTER" spacing="10">
                        <Label text="Admin Sistem" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                        <Circle radius="18" fill="#cbd5e1" />
                    </HBox>
                </HBox>
            </top>

            <!-- CENTER: Content -->
            <center>
                <VBox styleClass="content-pane">
                    
                    <!-- Statistics Cards -->
                    <HBox spacing="20">
                        <VBox styleClass="card" HBox.hgrow="ALWAYS">
                            <Label text="Total Mahasiswa Baru" styleClass="card-title" />
                            <Label text="1,245" styleClass="card-value" />
                        </VBox>
                        <VBox styleClass="card" HBox.hgrow="ALWAYS">
                            <Label text="Pendaftar Hari Ini" styleClass="card-title" />
                            <Label text="48" styleClass="card-value" />
                        </VBox>
                        <VBox styleClass="card" HBox.hgrow="ALWAYS">
                            <Label text="Diterima" styleClass="card-title" />
                            <Label text="890" styleClass="card-value" />
                        </VBox>
                    </HBox>
                    
                    <!-- CRUD Area / Table -->
                    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label text="Data Pendaftar Terbaru" styleClass="card-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Button text="+ Tambah Data" styleClass="btn-primary" />
                            <Button text="Edit Data" styleClass="btn-secondary" />
                            <Button text="Hapus Data" styleClass="btn-danger" />
                        </HBox>
                        
                        <TableView styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn text="ID Pendaftaran" prefWidth="120" />
                                <TableColumn text="Nama Lengkap" prefWidth="250" />
                                <TableColumn text="Program Studi" prefWidth="200" />
                                <TableColumn text="Tanggal Daftar" prefWidth="150" />
                                <TableColumn text="Status" prefWidth="120" />
                            </columns>
                        </TableView>
                    </VBox>
                    
                </VBox>
            </center>
        </BorderPane>
    </center>

</BorderPane>
