<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="controller.admin.DataMataKuliahController"
            styleClass="content-pane"
            prefWidth="1000.0" prefHeight="650.0">

    <SplitPane DividerPositions="0.35" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" 
               AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <items>
            
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <content>
                    <VBox spacing="15.0">
                        <padding>
                            <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                        </padding>
                        
                        <VBox spacing="8.0" style="-fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                            <Label text="Filter Mata Kuliah" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                            <GridPane hgap="10.0" vgap="8.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="35.0" />
                                    <ColumnConstraints percentWidth="65.0" />
                                </columnConstraints>
                                <children>
                                    <Label text="Program Studi:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbFilterProdi" promptText="Pilih Prodi" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                    
                                    <Label text="Semester:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbFilterSemester" promptText="Pilih Semester" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                </children>
                            </GridPane>
                            <HBox alignment="TOP_RIGHT" spacing="10.0">
                                <padding><Insets top="5.0"/></padding>
                                <Button fx:id="btnResetFilter" text="Reset" styleClass="button-secondary" />
                                <Button fx:id="btnCari" text="Cari" styleClass="button-primary" />
                            </HBox>
                        </VBox>

                        <VBox spacing="10.0">
                            <Label text="Form Kelola Mata Kuliah" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                            
                            <GridPane hgap="10.0" vgap="12.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="35.0" />
                                    <ColumnConstraints percentWidth="65.0" />
                                </columnConstraints>
                                <children>
                                    <Label text="Kode Matkul:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                    <TextField fx:id="txtKodeMatkul" promptText="Contox: MK001" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                    <Label text="Nama Matkul:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                    <TextField fx:id="txtNamaMatkul" promptText="Nama Mata Kuliah" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                    <Label text="SKS:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbSks" promptText="Pilih SKS" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                                    <Label text="Semester:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbSemester" promptText="Pilih Semester" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                                    <Label text="Program Studi:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbProdi" promptText="Pilih Program Studi" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                                </children>
                            </GridPane>

                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                <padding><Insets top="15.0" /></padding>
                                <Button fx:id="btnBatal" text="Batal" prefWidth="80.0" styleClass="button-danger" />
                                <Button fx:id="btnSimpan" text="Simpan" prefWidth="90.0" styleClass="button-success" />
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <VBox spacing="10.0">
                <padding>
                    <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                </padding>
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <children>
                            <Label text="Daftar Mata Kuliah" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="txtSearch" promptText="Cari Kode / Nama Matkul..." prefWidth="220.0" />
                        </children>
                    </HBox>
                    
                    <TableView fx:id="tblMataKuliah" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colKodeMatkul" text="Kode Matkul" prefWidth="100.0" />
                            <TableColumn fx:id="colNamaMatkul" text="Nama Mata Kuliah" prefWidth="250.0" />
                            <TableColumn fx:id="colSks" text="SKS" prefWidth="60.0" />
                            <TableColumn fx:id="colSemester" text="Semester" prefWidth="80.0" />
                            <TableColumn fx:id="colProdi" text="Program Studi" prefWidth="150.0" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>
            
        </items>
    </SplitPane>

</AnchorPane>