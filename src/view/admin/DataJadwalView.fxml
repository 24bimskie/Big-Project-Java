<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.admin.DataJadwalController"
      spacing="0"
      styleClass="content-pane"
      prefWidth="1000.0" prefHeight="650.0">

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Lihat Data">
                <content>
                    <VBox spacing="10.0">
                        <padding>
                            <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                        </padding>
                        <children>
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <children>
                                    <ComboBox fx:id="filterHari" promptText="Pilih Hari" prefWidth="150.0" />
                                    <ComboBox fx:id="filterDosen" promptText="Pilih Dosen" prefWidth="220.0" />
                                    <ComboBox fx:id="filterKelas" promptText="Pilih Kelas" prefWidth="180.0" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnResetFilter" text="Reset" onAction="#handleResetFilter" />
                                </children>
                            </HBox>
                            <TableView fx:id="tableJadwal" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colIdJadwal" text="ID" prefWidth="80.0" />
                                    <TableColumn fx:id="colHari" text="Hari" prefWidth="90.0" />
                                    <TableColumn fx:id="colJamMulai" text="Jam Mulai" prefWidth="90.0" />
                                    <TableColumn fx:id="colJamSelesai" text="Jam Selesai" prefWidth="110.0" />
                                    <TableColumn fx:id="colKodeMk" text="Matkul" prefWidth="150.0" />
                                    <TableColumn fx:id="colNidn" text="Dosen" prefWidth="150.0" />
                                    <TableColumn fx:id="colIdKelas" text="Kelas" prefWidth="80.0" />
                                    <TableColumn fx:id="colRuangan" text="Ruangan" prefWidth="110.0" />
                                    <!-- TAMBAHAN: dua kolom yang ada di Controller tapi hilang di FXML -->
                                    <TableColumn fx:id="colTahunAkademik" text="Tahun Akademik" prefWidth="120.0" />
                                    <TableColumn fx:id="colSemester" text="Semester" prefWidth="80.0" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                <Button text="Edit" onAction="#handleEdit" />
                                <!-- PERBAIKAN: tambah fx:id="btnHapus" -->
                                <Button fx:id="btnHapus" text="Hapus" onAction="#handleHapus" />
                            </HBox>
                        </children>
                    </VBox>
                </content>
            </Tab>
            <Tab text="Input Data">
                <content>
                    <ScrollPane fitToWidth="true" fitToHeight="true">
                        <content>
                            <VBox spacing="15.0">
                                <padding>
                                    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                                </padding>
                                <children>
                                    <VBox spacing="10.0" maxWidth="620.0">
                                        <children>
                                            <GridPane hgap="10.0" vgap="12.0">
                                                <columnConstraints>
                                                    <ColumnConstraints percentWidth="30.0" />
                                                    <ColumnConstraints percentWidth="70.0" />
                                                </columnConstraints>
                                                <children>
                                                    <Label text="ID Jadwal:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldIdJadwal" promptText="Opsional" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                                    <Label text="Dosen:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                                    <ComboBox fx:id="comboDosen" promptText="Pilih Dosen" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                                    <Label text="Matakuliah:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                                    <ComboBox fx:id="comboMataKuliah" promptText="Pilih Matakuliah" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                                                    <Label text="Kelas:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                                    <ComboBox fx:id="comboKelas" promptText="Pilih Kelas" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                                                    <Label text="Hari:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                                    <ComboBox fx:id="comboHari" promptText="Pilih Hari" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                                                    <Label text="Jam Mulai:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldJamMulai" promptText="Contoh: 08:00" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                                                    <Label text="Jam Selesai:" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldJamSelesai" promptText="Contoh: 10:30" GridPane.rowIndex="6" GridPane.columnIndex="1" />

                                                    <Label text="Ruangan:" GridPane.rowIndex="7" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldRuangan" promptText="Contoh: Lab Komputer 1" GridPane.rowIndex="7" GridPane.columnIndex="1" />

                                                    <Label text="Tahun Akademik:" GridPane.rowIndex="8" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldTahunAkademik" promptText="Contoh: 2024/2025" GridPane.rowIndex="8" GridPane.columnIndex="1" />

                                                    <Label text="Semester:" GridPane.rowIndex="9" GridPane.columnIndex="0" />
                                                    <ComboBox fx:id="comboSemester" promptText="Pilih Semester" maxWidth="Infinity" GridPane.rowIndex="9" GridPane.columnIndex="1" />
                                                </children>
                                            </GridPane>
                                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                                <children>
                                                    <Button fx:id="btnBatal" text="Batal" onAction="#handleBatal" />
                                                    <Button fx:id="btnTambah" text="Tambah" onAction="#handleTambah" />
                                                    <Button fx:id="btnEdit" text="Edit" onAction="#handleEdit" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>
        </tabs>
    </TabPane>

</VBox>