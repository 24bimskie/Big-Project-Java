<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controller.admin.DataDosenController"
      spacing="10" prefWidth="1100" prefHeight="700">

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>

    <!-- TabPane: header disembunyikan via CSS, dikendalikan dari sidebar -->
    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
             styleClass="hide-tab-header" style="-fx-background-color: transparent;">

        <!-- ====== Tab 0: Lihat Data ====== -->
        <Tab text="Lihat Data">
            <VBox VBox.vgrow="ALWAYS" spacing="10">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <VBox VBox.vgrow="ALWAYS" spacing="10" styleClass="card" style="-fx-padding: 10;">
                    <!-- Search Bar -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="fieldSearch" promptText="Cari NIP / Nama / Alamat..." prefWidth="280"/>
                        <Button fx:id="btnResetFilter" text="Reset" onAction="#handleResetFilter"/>
                    </HBox>

                    <TableView fx:id="tableDosen" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 8;
                                      -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                        <columns>
                            <TableColumn fx:id="colNo"     text="No"     prefWidth="50"  minWidth="50"
                                         style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colNip"    text="NIP"    prefWidth="140" minWidth="100"
                                         style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colNama"   text="Nama"   prefWidth="220" minWidth="150"/>
                            <TableColumn fx:id="colGender" text="Gender" prefWidth="90"  minWidth="80"
                                         style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="300" minWidth="150"/>
                        </columns>
                        <placeholder>
                            <Label text="Tidak ada data dosen."
                                   style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                        </placeholder>
                    </TableView>

                    <!-- Tombol Edit dan Hapus di tab Lihat Data -->
                    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
                        <Button fx:id="btnEdit"  text="Edit"  onAction="#handleEdit"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white;"/>
                        <Button fx:id="btnHapus" text="Hapus" onAction="#handleHapus"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>

        <!-- ====== Tab 1: Input Data ====== -->
        <Tab text="Input Data">
            <VBox spacing="15" alignment="TOP_LEFT">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                <VBox spacing="12" maxWidth="560"
                      style="-fx-background-color: white; -fx-padding: 25;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 2);">

                    <Label text="Form Data Dosen"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                    <GridPane hgap="15" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="NIP:"      GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="fieldNip" promptText="Masukkan NIP"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Nama:"     GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="fieldNama" promptText="Nama Lengkap Dosen"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Gender:"   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <ComboBox fx:id="comboGender" promptText="Pilih Gender" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Alamat:"   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="fieldAlamat" promptText="Alamat Dosen"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <PasswordField fx:id="fieldPassword" promptText="Password"
                                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </GridPane>

                    <!-- Action Buttons -->
                    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnTambah" text="Tambah" onAction="#handleTambah"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>
                        <Button fx:id="btnBatal"  text="Batal"  onAction="#handleBatal"
                                style="-fx-background-color: #94a3b8; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>

    </TabPane>

</VBox>
