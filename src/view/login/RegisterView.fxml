<?xml version="1.0" encoding="UTF-8"?>
<!-- View Register - Halaman Pendaftaran -->
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.RegisterController"
            prefWidth="800" prefHeight="500" styleClass="login-pane">

    <VBox alignment="CENTER" spacing="15.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <Text text="Registrasi Akun Baru" styleClass="login-title">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Text>
        
        <Text text="Silakan isi data untuk mendaftar" />

        <VBox maxWidth="300" spacing="10.0">
            <Label text="Username" />
            <TextField fx:id="usernameField" promptText="Masukkan username" styleClass="text-field" />
            
            <Label text="Password" />
            <PasswordField fx:id="passwordField" promptText="Masukkan password" styleClass="text-field" />

            <Label text="Level/Role" />
            <ComboBox fx:id="roleComboBox" promptText="Pilih Level" maxWidth="Infinity" styleClass="combo-box">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Admin" />
                        <String fx:value="Dosen" />
                        <String fx:value="Mahasiswa" />
                    </FXCollections>
                </items>
            </ComboBox>
            
            <Button text="Register" onAction="#handleRegister" maxWidth="Infinity" styleClass="btn-primary" />
            
            <Label fx:id="statusLabel" textFill="green" alignment="CENTER" maxWidth="Infinity" />
            
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="Sudah punya akun?" />
                <Hyperlink text="Login di sini" onAction="#handleBackToLogin" />
            </HBox>
        </VBox>
    </VBox>

</AnchorPane>
