<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.admin.DataProdiKelasController"
      spacing="0"
      styleClass="content-pane"
      prefWidth="1000.0" prefHeight="650.0">

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Lihat Data">
                <content>
                    <ScrollPane fitToWidth="true">
                        <content>
                            <VBox spacing="15.0">
                                <padding>
                                    <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
                                </padding>
                                <children>
                                    <Label text="Daftar Program Studi dan Kelas" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                    <TableView fx:id="tableProdi" VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn fx:id="colId" text="ID" prefWidth="80.0" />
                                            <TableColumn fx:id="colProdi" text="Program Studi" prefWidth="200.0" />
                                            <TableColumn fx:id="colKelas" text="Kelas" prefWidth="150.0" />
                                            <TableColumn fx:id="colTahunAkademik" text="Tahun Akademik" prefWidth="130.0" />
                                            <TableColumn fx:id="colAksi" text="Aksi" prefWidth="150.0" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>
            <Tab text="Input Data">
                <content>
                    <ScrollPane fitToWidth="true">
                        <content>
                            <VBox spacing="20.0">
                                <padding>
                                    <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
                                </padding>
                                <children>
                                    <VBox spacing="15.0">
                                        <children>
                                            <Label text="Form Input Data Prodi dan Kelas" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                            <GridPane hgap="10.0" vgap="10.0">
                                                <columnConstraints>
                                                    <ColumnConstraints percentWidth="25.0" />
                                                    <ColumnConstraints percentWidth="75.0" />
                                                </columnConstraints>
                                                <children>
                                                    <Label text="Nama Prodi:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldNamaProdi" promptText="Nama Program Studi" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                                    <Label text="Nama Kelas:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldNamaKelas" promptText="Contoh: 4A" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                                    <Label text="Tahun Akademik:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                                    <TextField fx:id="fieldTahunAkademik" promptText="Contoh: 2024/2025" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                                                </children>
                                            </GridPane>
                                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                                <Button fx:id="btnTambah" text="Tambah" onAction="#handleTambah" />
                                                <Button fx:id="btnEdit" text="Edit" onAction="#handleEdit" />
                                                <Button fx:id="btnHapus" text="Hapus" onAction="#handleHapus" />
                                                <Button fx:id="btnBatal" text="Batal" onAction="#handleBatal" />
                                            </HBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>
        </tabs>
    </TabPane>

</VBox>