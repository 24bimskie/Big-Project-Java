<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.admin.DataProdiKelasController"
      spacing="0"
      styleClass="content-pane"
      prefWidth="1000.0" prefHeight="650.0">

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Lihat Data">
                <content>
                    <SplitPane dividerPositions="0.5">
                        <items>
                            <VBox spacing="10.0">
                                <padding>
                                    <Insets top="15.0" right="10.0" bottom="15.0" left="10.0" />
                                </padding>
                                <children>
                                    <Label text="Daftar Program Studi" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                    <TableView fx:id="tableProdi" VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn fx:id="colIdProdi" text="ID Prodi" prefWidth="120.0" />
                                            <TableColumn fx:id="colNamaProdi" text="Nama Prodi" prefWidth="220.0" />
                                            <TableColumn fx:id="colFakultas" text="Fakultas" prefWidth="180.0" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                            <VBox spacing="10.0">
                                <padding>
                                    <Insets top="15.0" right="10.0" bottom="15.0" left="10.0" />
                                </padding>
                                <children>
                                    <Label text="Daftar Kelas" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                    <TableView fx:id="tableKelas" VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn fx:id="colIdKelas" text="ID Kelas" prefWidth="120.0" />
                                            <TableColumn fx:id="colNamaKelas" text="Nama Kelas" prefWidth="220.0" />
                                            <TableColumn fx:id="colTahunAkademik" text="Tahun Akademik" prefWidth="170.0" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                        </items>
                    </SplitPane>
                </content>
            </Tab>
            <Tab text="Input Data">
                <content>
                    <SplitPane dividerPositions="0.5">
                        <items>
                            <VBox spacing="15.0">
                                <padding>
                                    <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
                                </padding>
                                <children>
                                    <Label text="Form Program Studi" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                    <GridPane hgap="10.0" vgap="10.0">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="35.0" />
                                            <ColumnConstraints percentWidth="65.0" />
                                        </columnConstraints>
                                        <children>
                                            <Label text="ID Prodi:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                            <TextField fx:id="fieldIdProdi" promptText="Contoh: AGRI" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                            <Label text="Nama Prodi:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                            <TextField fx:id="fieldNamaProdi" promptText="Nama Program Studi" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                            <Label text="Fakultas:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                            <TextField fx:id="fieldFakultas" promptText="Fakultas" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                                        </children>
                                    </GridPane>
                                    <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                        <Button fx:id="btnTambahProdi" text="Tambah" onAction="#handleTambahProdi" />
                                        <Button fx:id="btnEditProdi" text="Edit" onAction="#handleEditProdi" />
                                        <Button fx:id="btnHapusProdi" text="Hapus" onAction="#handleHapusProdi" />
                                        <Button fx:id="btnBatalProdi" text="Batal" onAction="#handleBatalProdi" />
                                    </HBox>
                                </children>
                            </VBox>
                            <VBox spacing="15.0">
                                <padding>
                                    <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
                                </padding>
                                <children>
                                    <Label text="Form Kelas" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                    <Label fx:id="labelProdiKelas" text="Pilih prodi terlebih dahulu" />
                                    <GridPane hgap="10.0" vgap="10.0">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="35.0" />
                                            <ColumnConstraints percentWidth="65.0" />
                                        </columnConstraints>
                                        <children>
                                            <Label text="ID Kelas:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                            <TextField fx:id="fieldIdKelas" promptText="Contoh: KLS001" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                            <Label text="Nama Kelas:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                            <TextField fx:id="fieldNamaKelas" promptText="Contoh: 4A" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                            <Label text="Tahun Akademik:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                            <TextField fx:id="fieldTahunAkademik" promptText="Contoh: 2024/2025" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                                        </children>
                                    </GridPane>
                                    <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                        <Button fx:id="btnTambahKelas" text="Tambah" onAction="#handleTambahKelas" />
                                        <Button fx:id="btnEditKelas" text="Edit" onAction="#handleEditKelas" />
                                        <Button fx:id="btnHapusKelas" text="Hapus" onAction="#handleHapusKelas" />
                                        <Button fx:id="btnBatalKelas" text="Batal" onAction="#handleBatalKelas" />
                                    </HBox>
                                </children>
                            </VBox>
                        </items>
                    </SplitPane>
                </content>
            </Tab>
        </tabs>
    </TabPane>

</VBox>