<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="controller.admin.DataProdiKelasController"
            styleClass="content-pane"
            prefWidth="1000.0" prefHeight="650.0">

    <SplitPane DividerPositions="0.5" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" 
               AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <items>
            
            <VBox spacing="15.0">
                <padding>
                    <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                </padding>
                <children>
                    <Label text="Kelola Program Studi (Prodi)" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2C3E50;" />
                    
                    <VBox spacing="10.0" style="-fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="30.0" />
                                <ColumnConstraints percentWidth="70.0" />
                            </columnConstraints>
                            <children>
                                <Label text="Kode Prodi:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <TextField fx:id="txtKodeProdi" promptText="Contoh: AGRI" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                <Label text="Nama Prodi:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <TextField fx:id="txtNamaProdi" promptText="Nama Program Studi" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            </children>
                        </GridPane>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <padding><Insets top="5.0" /></padding>
                            <Button fx:id="btnBatalProdi" text="Batal" styleClass="button-danger" />
                            <Button fx:id="btnSimpanProdi" text="Simpan" styleClass="button-success" />
                        </HBox>
                    </VBox>

                    <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                        <Label text="Daftar Program Studi" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <TableView fx:id="tblProdi" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colKodeProdi" text="Kode Prodi" prefWidth="120.0" />
                                <TableColumn fx:id="colNamaProdi" text="Nama Program Studi" prefWidth="250.0" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </children>
            </VBox>

            <VBox spacing="15.0">
                <padding>
                    <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                </padding>
                <children>
                    <Label text="Kelola Kelas" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2C3E50;" />
                    
                    <VBox spacing="10.0" style="-fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="30.0" />
                                <ColumnConstraints percentWidth="70.0" />
                            </columnConstraints>
                            <children>
                                <Label text="Program Studi:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <ComboBox fx:id="cmbProdiKelas" promptText="Pilih Prodi" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                <Label text="Nama Kelas:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <TextField fx:id="txtNamaKelas" promptText="Contoh: 4A, 2B, dll" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            </children>
                        </GridPane>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <padding><Insets top="5.0" /></padding>
                            <Button fx:id="btnBatalKelas" text="Batal" styleClass="button-danger" />
                            <Button fx:id="btnSimpanKelas" text="Simpan" styleClass="button-success" />
                        </HBox>
                    </VBox>

                    <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Daftar Kelas" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="cmbFilterProdi" promptText="Filter Prodi" prefWidth="150.0" />
                            </children>
                        </HBox>
                        
                        <TableView fx:id="tblKelas" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colProdiMilikKelas" text="Program Studi" prefWidth="180.0" />
                                <TableColumn fx:id="colNamaKelas" text="Nama Kelas" prefWidth="150.0" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columns>
                        </TableView>
                    </VBox>
                </children>
            </VBox>
            
        </items>
    </SplitPane>

</AnchorPane>