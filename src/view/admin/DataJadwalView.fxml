<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="controller.admin.DataJadwalController"
            styleClass="content-pane"
            prefWidth="1000.0" prefHeight="650.0">

    <SplitPane DividerPositions="0.35" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" 
               AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <items>
            
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <content>
                    <VBox spacing="15.0">
                        <padding>
                            <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                        </padding>
                        
                        <VBox spacing="8.0" style="-fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                            <Label text="Filter Jadwal" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                            <GridPane hgap="10.0" vgap="8.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30.0" />
                                    <ColumnConstraints percentWidth="70.0" />
                                </columnConstraints>
                                <children>
                                    <Label text="Hari:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbFilterHari" promptText="Pilih Hari" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                    
                                    <Label text="Kelas:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbFilterKelas" promptText="Pilih Kelas" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                </children>
                            </GridPane>
                            <HBox alignment="TOP_RIGHT" spacing="10.0">
                                <padding><Insets top="5.0"/></padding>
                                <Button fx:id="btnResetFilter" text="Reset" styleClass="button-secondary" />
                                <Button fx:id="btnCari" text="Cari" styleClass="button-primary" />
                            </HBox>
                        </VBox>

                        <VBox spacing="10.0">
                            <Label text="Form Kelola Jadwal" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                            
                            <GridPane hgap="10.0" vgap="12.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30.0" />
                                    <ColumnConstraints percentWidth="70.0" />
                                </columnConstraints>
                                <children>
                                    <Label text="Dosen:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbDosen" promptText="Pilih Dosen" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                    <Label text="Matakuliah:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbMatkul" promptText="Pilih Matakuliah" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                    <Label text="Kelas:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbKelas" promptText="Pilih Kelas" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                                    <Label text="Hari:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                    <ComboBox fx:id="cmbHari" promptText="Pilih Hari" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                                    <Label text="Jam Masuk:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                    <TextField fx:id="txtJamMasuk" promptText="Contoh: 08:00" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                                    <Label text="Jam Selesai:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                                    <TextField fx:id="txtJamSelesai" promptText="Contoh: 10:30" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                                    <Label text="Ruangan:" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                                    <TextField fx:id="txtRuangan" promptText="Contoh: Lab Komputer 1" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                                </children>
                            </GridPane>

                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                <padding><Insets top="15.0" /></padding>
                                <Button fx:id="btnBatal" text="Batal" prefWidth="80.0" styleClass="button-danger" />
                                <Button fx:id="btnSimpan" text="Simpan" prefWidth="90.0" styleClass="button-success" />
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <VBox spacing="10.0">
                <padding>
                    <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                </padding>
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <children>
                            <Label text="Daftar Jadwal Perkuliahan" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="txtSearch" promptText="Cari Dosen / Matkul..." prefWidth="200.0" />
                        </children>
                    </HBox>
                    
                    <TableView fx:id="tblJadwal" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colHari" text="Hari" prefWidth="80.0" />
                            <TableColumn fx:id="colJam" text="Waktu" prefWidth="110.0" />
                            <TableColumn fx:id="colMatkul" text="Matakuliah" prefWidth="150.0" />
                            <TableColumn fx:id="colDosen" text="Dosen" prefWidth="150.0" />
                            <TableColumn fx:id="colKelas" text="Kelas" prefWidth="70.0" />
                            <TableColumn fx:id="colRuangan" text="Ruangan" prefWidth="100.0" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>
            
        </items>
    </SplitPane>

</AnchorPane>