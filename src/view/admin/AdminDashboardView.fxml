<?xml version="1.0" encoding="UTF-8"?>
<!-- View Dashboard Admin -->
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.admin.AdminDashboardController"
            prefWidth="1200" prefHeight="750" styleClass="dashboard-pane" stylesheets="@../../style/style.css">

    <!-- TOP: Header dengan info user -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header" prefHeight="70">
            <padding>
                <Insets top="10" right="30" bottom="10" left="30"/>
            </padding>
            
            <Label text="SAM Dashboard Admin" styleClass="header-title-brand"/>

            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER_RIGHT" spacing="20">
                <HBox alignment="CENTER" spacing="12" styleClass="user-profile-box">
                    <VBox alignment="CENTER_LEFT" spacing="0">
                        <Label fx:id="labelNamaUser" text="Nama User" visible="false" managed="false"/>
                        <Label fx:id="labelRole" text="Admin" styleClass="badge-role"/>
                    </VBox>
                </HBox>
                <Button fx:id="btnLogout" text="Logout" onAction="#handleLogout" styleClass="btn-logout-modern">
                    <graphic>
                        <Region styleClass="icon-logout"/>
                    </graphic>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- LEFT: Sidebar menu navigasi -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260">
            <!-- Header Sidebar Tetap Terlihat -->
            <VBox>
                <padding>
                    <Insets top="25" right="15" bottom="10" left="15"/>
                </padding>
                <Label text="MAIN MENU" styleClass="sidebar-section-title"/>
            </VBox>

            <!-- Area Menu Scrollable -->
            <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" pannable="true" VBox.vgrow="ALWAYS">
                <VBox spacing="8" styleClass="sidebar-menu-container">
                    <padding>
                        <Insets right="15" bottom="25" left="15"/>
                    </padding>

                    <Button fx:id="btnMahasiswa" text="Data Mahasiswa" onAction="#handleMenuMahasiswaToggle" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic>
                            <Region styleClass="icon-mahasiswa"/>
                        </graphic>
                    </Button>
                    <VBox fx:id="submenuMahasiswa" visible="false" managed="false" spacing="4" styleClass="submenu-container">
                        <Button fx:id="btnMahasiswaLihat" text="Lihat Data" onAction="#handleMenuMahasiswaLihat" maxWidth="Infinity" styleClass="submenu-btn" />
                        <Button fx:id="btnMahasiswaInput" text="Input Data" onAction="#handleMenuMahasiswaInput" maxWidth="Infinity" styleClass="submenu-btn" />
                    </VBox>

                    <Button fx:id="btnDosen" text="Data Dosen" onAction="#handleMenuDosenToggle" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic>
                            <Region styleClass="icon-dosen"/>
                        </graphic>
                    </Button>
                    <VBox fx:id="submenuDosen" visible="false" managed="false" spacing="4" styleClass="submenu-container">
                        <Button fx:id="btnDosenLihat" text="Lihat Data" onAction="#handleMenuDosenLihat" maxWidth="Infinity" styleClass="submenu-btn" />
                        <Button fx:id="btnDosenInput" text="Input Data" onAction="#handleMenuDosenInput" maxWidth="Infinity" styleClass="submenu-btn" />
                    </VBox>

                    <Button fx:id="btnProdiKelas" text="Data Prodi &amp; Kelas" onAction="#handleMenuProdiKelasToggle" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic>
                            <Region styleClass="icon-prodi"/>
                        </graphic>
                    </Button>
                    <VBox fx:id="submenuProdiKelas" visible="false" managed="false" spacing="4" styleClass="submenu-container">
                        <Button fx:id="btnProdiKelasLihat" text="Lihat Data" onAction="#handleMenuProdiKelasLihat" maxWidth="Infinity" styleClass="submenu-btn" />
                        <Button fx:id="btnProdiKelasInput" text="Input Data" onAction="#handleMenuProdiKelasInput" maxWidth="Infinity" styleClass="submenu-btn" />
                    </VBox>

                    <Button fx:id="btnMataKuliah" text="Data Mata Kuliah" onAction="#handleMenuMataKuliahToggle" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic>
                            <Region styleClass="icon-matkul"/>
                        </graphic>
                    </Button>
                    <VBox fx:id="submenuMataKuliah" visible="false" managed="false" spacing="4" styleClass="submenu-container">
                        <Button fx:id="btnMataKuliahLihat" text="Lihat Data" onAction="#handleMenuMataKuliahLihat" maxWidth="Infinity" styleClass="submenu-btn" />
                        <Button fx:id="btnMataKuliahInput" text="Input Data" onAction="#handleMenuMataKuliahInput" maxWidth="Infinity" styleClass="submenu-btn" />
                    </VBox>

                    <Button fx:id="btnJadwal" text="Data Jadwal" onAction="#handleMenuJadwalToggle" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic>
                            <Region styleClass="icon-jadwal"/>
                        </graphic>
                    </Button>
                    <VBox fx:id="submenuJadwal" visible="false" managed="false" spacing="4" styleClass="submenu-container">
                        <Button fx:id="btnJadwalLihat" text="Lihat Data" onAction="#handleMenuJadwalLihat" maxWidth="Infinity" styleClass="submenu-btn" />
                        <Button fx:id="btnJadwalInput" text="Input Data" onAction="#handleMenuJadwalInput" maxWidth="Infinity" styleClass="submenu-btn" />
                    </VBox>
                    
                    <Region VBox.vgrow="ALWAYS" />
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- CENTER: Content area (berubah sesuai menu yang dipilih) -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding>
                <Insets top="25" right="30" bottom="30" left="30"/>
            </padding>
            <!-- Konten dari FXML lain akan dimuat di sini oleh Controller -->
        </StackPane>
    </center>

</BorderPane>
