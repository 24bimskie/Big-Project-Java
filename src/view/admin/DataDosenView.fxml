<?xml version="1.0" encoding="UTF-8"?>
<!-- View Data Dosen (Admin) — Kolom DB: nip, nama, gender, alamat, password -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controller.admin.DataDosenController"
      spacing="15" styleClass="content-pane" prefWidth="900" prefHeight="600">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Search Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="fieldSearch" promptText="Cari NIP / Nama / Alamat..." prefWidth="280"/>
        <Button fx:id="btnResetFilter" text="Reset" onAction="#handleResetFilter"/>
    </HBox>

    <!-- Content Tabs (header disembunyikan via CSS .hide-tab-header) -->
    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
             styleClass="hide-tab-header" style="-fx-background-color: transparent;">

        <!-- ====== Tab 1: Lihat Data ====== -->
        <Tab text="Lihat Data">
            <VBox VBox.vgrow="ALWAYS">
                <TableView fx:id="tableDosen" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 8;
                                  -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                    <columns>
                        <TableColumn fx:id="colNo"     text="No"    prefWidth="55"
                                     style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colNip"    text="NIP"   prefWidth="150"/>
                        <TableColumn fx:id="colNama"   text="Nama"  prefWidth="220"/>
                        <TableColumn fx:id="colGender" text="L/P"   prefWidth="70"
                                     style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="350"/>
                    </columns>
                    <placeholder>
                        <Label text="Tidak ada data dosen."
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                    </placeholder>
                </TableView>
            </VBox>
        </Tab>

        <!-- ====== Tab 2: Input Data ====== -->
        <Tab text="Input Data">
            <VBox spacing="15" alignment="TOP_LEFT">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                <VBox spacing="12" maxWidth="520"
                      style="-fx-background-color: white; -fx-padding: 25;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 2);">

                    <GridPane hgap="15" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="NIP:"             GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="fieldNip"    GridPane.columnIndex="1" GridPane.rowIndex="0"
                                   promptText="Nomor Induk Pegawai"/>

                        <Label text="Nama:"            GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="fieldNama"   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Jenis Kelamin:"   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <ComboBox fx:id="comboGender" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Alamat:"          GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="fieldAlamat" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Password:"            GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <PasswordField fx:id="fieldPassword"
                                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </GridPane>

                    <!-- Action Buttons -->
                    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnTambah" text="Tambah" onAction="#handleTambah"
                                styleClass="btn-primary" style="-fx-background-color: #3b82f6;"/>
                        <Button fx:id="btnEdit"   text="Edit"   onAction="#handleEdit"
                                styleClass="btn-primary" style="-fx-background-color: #f59e0b;"/>
                        <Button fx:id="btnHapus"  text="Hapus"  onAction="#handleHapus"
                                styleClass="btn-primary" style="-fx-background-color: #ef4444;"/>
                        <Button fx:id="btnBatal"  text="Batal"  onAction="#handleBatal"
                                styleClass="btn-primary" style="-fx-background-color: #94a3b8;"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>

    </TabPane>

</VBox>
