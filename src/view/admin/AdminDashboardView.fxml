<?xml version="1.0" encoding="UTF-8"?>
<!-- View Dashboard Admin -->
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.admin.AdminDashboardController"
            prefWidth="1100" prefHeight="700" styleClass="dashboard-pane" stylesheets="@../../style/style.css">

    <!-- TOP: Header dengan info user -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header" prefHeight="70">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            <Label text="Sistem Absensi Mahasiswa - Admin Dashboard" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="labelNamaUser" text="Nama User" styleClass="header-user"/>
                    <Label fx:id="labelRole" text="Role: Admin" styleClass="header-role"/>
                </VBox>
                <Button fx:id="btnLogout" text="Logout" onAction="#handleLogout" styleClass="btn-logout" />
            </HBox>
        </HBox>
    </top>

    <!-- LEFT: Sidebar menu navigasi -->
    <left>
        <VBox spacing="12" styleClass="sidebar" prefWidth="250">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>
            

            <Button fx:id="btnMahasiswa" text="Data Mahasiswa ▼" onAction="#handleMenuMahasiswaToggle" maxWidth="Infinity" styleClass="sidebar-btn" />
            <VBox fx:id="submenuMahasiswa" visible="false" managed="false" spacing="5">
                <padding><Insets left="15"/></padding>
                <Button fx:id="btnMahasiswaLihat" text="Lihat Data" onAction="#handleMenuMahasiswaLihat" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
                <Button fx:id="btnMahasiswaInput" text="Input Data" onAction="#handleMenuMahasiswaInput" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
            </VBox>
            <Button fx:id="btnDosen" text="Data Dosen ▼" onAction="#handleMenuDosenToggle" maxWidth="Infinity" styleClass="sidebar-btn" />
            <VBox fx:id="submenuDosen" visible="false" managed="false" spacing="5">
                <padding><Insets left="15"/></padding>
                <Button fx:id="btnDosenLihat" text="Lihat Data" onAction="#handleMenuDosenLihat" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
                <Button fx:id="btnDosenInput" text="Input Data" onAction="#handleMenuDosenInput" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
            </VBox>
            <Button fx:id="btnProdiKelas" text="Data Prodi &amp; Kelas ▼" onAction="#handleMenuProdiKelasToggle" maxWidth="Infinity" styleClass="sidebar-btn" />
            <VBox fx:id="submenuProdiKelas" visible="false" managed="false" spacing="5">
                <padding><Insets left="15"/></padding>
                <Button fx:id="btnProdiKelasLihat" text="Lihat Data" onAction="#handleMenuProdiKelasLihat" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
                <Button fx:id="btnProdiKelasInput" text="Input Data" onAction="#handleMenuProdiKelasInput" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
            </VBox>
            <Button fx:id="btnMataKuliah" text="Data Mata Kuliah ▼" onAction="#handleMenuMataKuliahToggle" maxWidth="Infinity" styleClass="sidebar-btn" />
            <VBox fx:id="submenuMataKuliah" visible="false" managed="false" spacing="5">
                <padding><Insets left="15"/></padding>
                <Button fx:id="btnMataKuliahLihat" text="Lihat Data" onAction="#handleMenuMataKuliahLihat" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
                <Button fx:id="btnMataKuliahInput" text="Input Data" onAction="#handleMenuMataKuliahInput" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
            </VBox>
            <Button fx:id="btnJadwal" text="Data Jadwal ▼" onAction="#handleMenuJadwalToggle" maxWidth="Infinity" styleClass="sidebar-btn" />
            <VBox fx:id="submenuJadwal" visible="false" managed="false" spacing="5">
                <padding><Insets left="15"/></padding>
                <Button fx:id="btnJadwalLihat" text="Lihat Data" onAction="#handleMenuJadwalLihat" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
                <Button fx:id="btnJadwalInput" text="Input Data" onAction="#handleMenuJadwalInput" maxWidth="Infinity" styleClass="sidebar-btn" style="-fx-font-size: 13px; -fx-padding: 8px 15px;" />
            </VBox>
            
            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <!-- CENTER: Content area (berubah sesuai menu yang dipilih) -->
    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </padding>
            <!-- Konten dari FXML lain akan dimuat di sini oleh Controller -->
        </StackPane>
    </center>

</BorderPane>
