<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.admin.DataMataKuliahController"
      spacing="0"
      styleClass="content-pane"
      prefWidth="1000.0" prefHeight="650.0">

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Lihat Data">
                <content>
                    <VBox spacing="10.0">
                        <padding>
                            <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
                        </padding>
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <TextField fx:id="txtSearch" promptText="Cari Kode / Nama Matkul..." prefWidth="260.0" />
                                    <ComboBox fx:id="cmbFilterProdi" promptText="Semua Prodi" prefWidth="180.0" />
                                    <ComboBox fx:id="cmbFilterSemester" promptText="Semua Semester" prefWidth="180.0" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnResetFilter" text="Reset" onAction="#handleResetFilter" />
                                    <Button fx:id="btnCari" text="Cari" onAction="#handleCari" />
                                </children>
                            </HBox>
                            <TableView fx:id="tblMataKuliah" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colKodeMatkul" text="Kode Matkul" prefWidth="110.0" />
                                    <TableColumn fx:id="colNamaMatkul" text="Nama Mata Kuliah" prefWidth="240.0" />
                                    <TableColumn fx:id="colSks" text="SKS" prefWidth="70.0" />
                                    <TableColumn fx:id="colSemester" text="Semester" prefWidth="90.0" />
                                    <TableColumn fx:id="colProdi" text="Program Studi" prefWidth="180.0" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                <Button text="Edit" onAction="#handleEdit" />
                                <Button text="Hapus" onAction="#handleHapus" />
                            </HBox>
                        </children>
                    </VBox>
                </content>
            </Tab>
            <Tab text="Input Data">
                <content>
                    <ScrollPane fitToWidth="true" fitToHeight="true">
                        <content>
                            <VBox spacing="15.0">
                                <padding>
                                    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                                </padding>
                                <children>
                                    <VBox spacing="10.0" maxWidth="560.0">
                                        <children>
                                            <GridPane hgap="10.0" vgap="12.0">
                                                <columnConstraints>
                                                    <ColumnConstraints percentWidth="35.0" />
                                                    <ColumnConstraints percentWidth="65.0" />
                                                </columnConstraints>
                                                <children>
                                                    <Label text="Kode Matkul:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                                    <TextField fx:id="txtKodeMatkul" promptText="Contoh: MK001"
                                                               GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                                    <Label text="Nama Matkul:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                                    <TextField fx:id="txtNamaMatkul" promptText="Nama Mata Kuliah"
                                                               GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                                    <Label text="SKS:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                                    <ComboBox fx:id="cmbSks" promptText="Pilih SKS" maxWidth="Infinity"
                                                              GridPane.rowIndex="2" GridPane.columnIndex="1" />

                                                    <Label text="Semester:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                                    <ComboBox fx:id="cmbSemester" promptText="Pilih Semester" maxWidth="Infinity"
                                                              GridPane.rowIndex="3" GridPane.columnIndex="1" />

                                                    <Label text="Program Studi:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                                    <TextField fx:id="txtProdi" promptText="Ketik Program Studi"
                                                               GridPane.rowIndex="4" GridPane.columnIndex="1" />
                                                </children>
                                            </GridPane>
                                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                                <children>
                                                    <Button fx:id="btnBatal" text="Batal" onAction="#handleBatal" />
                                                    <Button fx:id="btnSimpan" text="Simpan" onAction="#handleSimpan" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>
        </tabs>
    </TabPane>

</VBox>